{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [{"type": "command", "command": "bash .claude/hooks/track_edit.sh"}]
      },
      {
        "matcher": "Write",
        "hooks": [{"type": "command", "command": "bash .claude/hooks/track_new.sh"}]
      },
      {
        "matcher": "Bash",
        "hooks": [{"type": "command", "command": "bash .claude/hooks/track_delete.sh"}]
      }
    ]
  }
}
